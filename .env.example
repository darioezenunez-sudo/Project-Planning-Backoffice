# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Supabase (crear proyecto en https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database — usar connection pool (PgBouncer) para app, direct para migrations
# Supabase: Settings → Database → Connection string (URI) → Port 6543 = pool, 5432 = direct
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=10"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Vercel (auto en deploy)
VERCEL_URL=
# Upstash for Redis — Vercel inyecta estos vars automáticamente al linkear el store
# Vercel Dashboard → Storage → Upstash for Redis → Connect to project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External (opcional en Fase 0)
RESEND_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=minimo-32-caracteres-para-seguridad
ENCRYPTION_KEY=minimo-32-caracteres-para-encryption
CRON_SECRET=minimo-16-caracteres-para-cron

E2E_TEST_EMAIL=xxxxxx@gmail.com
E2E_TEST_PASSWORD=xxxxxxx
PLAYWRIGHT_BASE_URL=http://localhost:3000

