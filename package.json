    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:health": "tsx scripts/db-health.ts",
    "db:analyze": "tsx scripts/db-analyze.ts",
    "db:cleanup": "tsx scripts/db-cleanup.ts",
    "db:vacuum": "tsx scripts/db-vacuum.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "load-test": "k6 run scripts/load-test.js",
    "prepare": "husky",
    "validate": "pnpm run lint && pnpm run type-check && pnpm run test:run"
